# Production Environment Configuration for Kiongozi API Server
# IMPORTANT: Update these values for your production deployment

# Server Configuration
NODE_ENV=production
PORT=10000

# CORS Configuration (update with your production domains)
ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# Rate Limiting (stricter in production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=CHANGE-THIS-TO-A-STRONG-SECRET-IN-PRODUCTION
JWT_EXPIRES_IN=7d

# AI Configuration (use your production OpenAI key)
OPENAI_API_KEY=your-production-openai-key

# Supabase Configuration (use your production Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Security Configuration - PRODUCTION SETTINGS
# Enable IP blocking protection
ENABLE_IP_BLOCKING=true

# Emergency bypass IPs - ADD YOUR PRODUCTION ADMIN IPs HERE
# Replace these with your actual admin/office IP addresses
EMERGENCY_BYPASS_IPS=your.admin.ip.1,your.admin.ip.2

# Suspicious activity thresholds (stricter in production)
SUSPICIOUS_PATTERNS_THRESHOLD=2
BLOCKED_IP_CLEANUP_INTERVAL=1800000

# Security features (all enabled in production)
ENABLE_USER_AGENT_BLOCKING=true
ENABLE_CONTENT_FILTERING=true
AUTO_BLOCK_AFTER_VIOLATIONS=2

# Additional Production Security
# Enable comprehensive logging
ENABLE_SECURITY_LOGGING=true
LOG_BLOCKED_REQUESTS=true
ALERT_ON_MULTIPLE_BLOCKS=true