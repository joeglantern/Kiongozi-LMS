# Render Environment Variables Template
# Copy these to your Render service environment variables

# Server Configuration
NODE_ENV=production
PORT=10000

# CORS Configuration (UPDATE WITH YOUR ACTUAL DOMAINS)
ALLOWED_ORIGINS=https://your-admin-panel.netlify.app,https://your-main-app.netlify.app,http://localhost:3000,http://localhost:3001

# Security Configuration (set to 'true' only if you want to enable IP blocking)
# ENABLE_IP_BLOCKING=false

# Rate Limiting (Same as current)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# JWT Configuration (CHANGE THIS SECRET IN PRODUCTION!)
JWT_SECRET=kiongozi-super-secret-jwt-key-change-in-production-2024-RENDER
JWT_EXPIRES_IN=7d

# AI Configuration (Set your OpenAI API key in Render dashboard)
OPENAI_API_KEY=your-openai-api-key-here

